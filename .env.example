# ============================================================
# Silent Protocol · 环境配置示例
# ============================================================
# 复制此文件为 .env 并填入你的 API Key 和路径配置
# cp .env.example .env
# ============================================================

# --- DeepSeek API（翻译官/任务拆解）---
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# --- Claude API（顾问团/知识后盾）---
# 可选：如果不配置，本地 Claude 将不会向云端求助
CLAUDE_API_KEY=sk-ant-your-claude-api-key-here
CLAUDE_API_BASE=https://api.anthropic.com/v1

# --- neca 网关配置 ---
NECA_PORT=3000
NECA_HOST=localhost
NECA_LOG_LEVEL=info

# --- 路径白名单（允许 neca 读写的目录）---
# 多个路径用逗号分隔；~ 表示用户主目录
NECA_ALLOWED_PATHS=~,./projects,C:\tmmp\majiong-win

# --- Shell 命令白名单 ---
# 允许执行的命令，用逗号分隔
NECA_ALLOWED_COMMANDS=ls,dir,cd,pwd,echo,cat,type,git,node,npx,npm,python,gcc,cp,mv,mkdir,claude

# --- 紧凑协议编码器 ---
# 可选: json | msgpack | protobuf | capnp
# json 为默认，二进制编码器需要额外安装依赖
PROTOCOL_CODEC=json

# --- 速率限制 ---
# 单个消息类型最大调用次数/分钟
RATE_LIMIT_PER_TYPE=60
# 总消息量最大调用次数/分钟
RATE_LIMIT_TOTAL=300

# --- 会话超时 ---
# 不同类型消息的默认超时（毫秒）
EXEC_TIMEOUT=30000
READ_TIMEOUT=5000
WRITE_TIMEOUT=5000
SEARCH_TIMEOUT=10000
DELEGATE_TIMEOUT=300000
QUERY_TIMEOUT=60000
PING_TIMEOUT=3000

# ============================================================
# neca2（右手）专用配置
# ============================================================

# --- neca2 HTTP 传输层 ---
# 云端 DS 通过这个端口发送紧凑协议消息到 neca2
NECA2_HTTP_PORT=3101
# API Key 保护 HTTP 端点（留空则开发模式不鉴权）
NECA2_API_KEY=

# --- neca2 子进程管理器 ---
# 最大并发子进程数
NECA2_MAX_PROCESSES=4

# --- neca2 Relay（云端 API 中继）---
# Claude API
ANTHROPIC_API_KEY=
NECA2_RELAY_MODEL=claude-sonnet-4-20250514
NECA2_RELAY_MAX_TOKENS=4096
NECA2_RELAY_TIMEOUT=60000
# DeepSeek API（默认用主配置的 DEEPSEEK_API_KEY）
NECA2_RELAY_DS_MODEL=deepseek-chat
# 默认中继提供商（claude / deepseek）
NECA2_DEFAULT_RELAY=claude
